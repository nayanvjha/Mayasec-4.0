# MAYASEC Docker Compose Configuration
# See docker-compose.yml for service definitions

# Database Configuration
DB_NAME=mayasec
DB_USER=mayasec
DB_PASSWORD=mayasec_secure_password

# Service Ports
API_PORT=5000
INGESTOR_PORT=5001

# Security
SECRET_KEY=your-secret-key-change-this-in-production

# External APIs
GEMINI_API_KEY=your-gemini-api-key-here

# Logging
LOG_LEVEL=INFO
FLASK_ENV=production

# Message Queue (optional, for future async processing)
KAFKA_BROKER=
REDIS_URL=

# Analysis Configuration
ANALYSIS_BATCH_SIZE=10
ANALYSIS_TIMEOUT=30
